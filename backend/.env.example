PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5434/deploypulse
REDIS_URL=redis://localhost:6380

# ── Production note ────────────────────────────────
# In production (docker-compose.prod), hostnames are Docker service names:
#   DATABASE_URL=postgresql://postgres:PASSWORD@postgres:5432/deploypulse
#   REDIS_URL=redis://redis:6379
# Copy backend/.env.prod.example → backend/.env before deploying.
# ───────────────────────────────────────────────────

JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_FROM_EMAIL=noreply@deploypulse.com

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER_ID=price_...
STRIPE_PRICE_PRO_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=http://localhost:5173
