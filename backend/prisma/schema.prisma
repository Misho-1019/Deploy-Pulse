generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MonitorMode {
  KEEP_ALIVE
  FULL_MONITORING
}

enum MonitorStatus {
  UP
  DOWN
  PENDING
}

enum CheckStatus {
  UP
  DOWN
}

enum NotificationChannel {
  EMAIL
  SLACK
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum AlertType {
  DOWN
  RECOVERY
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password               String
  name                   String?
  plan                   Plan      @default(FREE)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  slackWebhookUrl        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  monitors Monitor[]
}

model Monitor {
  id        String             @id @default(uuid())
  name      String
  url       String
  mode      MonitorMode        @default(KEEP_ALIVE)
  interval  Int                @default(300)
  status    MonitorStatus      @default(PENDING)
  channels  NotificationChannel[] @default([EMAIL])
  userId    String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  checks    Check[]
  alerts    Alert[]
  incidents Incident[]

  @@index([userId])
}

model Check {
  id           String      @id @default(uuid())
  statusCode   Int?
  responseTime Int?
  error        String?
  status       CheckStatus
  checkedAt    DateTime    @default(now())
  monitorId    String

  monitor      Monitor     @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, checkedAt])
}

model Alert {
  id        String    @id @default(uuid())
  type      AlertType
  message   String
  read      Boolean   @default(false)
  sentAt    DateTime  @default(now())
  monitorId String

  monitor   Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId])
}

model Incident {
  id         String    @id @default(uuid())
  startedAt  DateTime
  resolvedAt DateTime?
  monitorId  String

  monitor    Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, resolvedAt])
}
